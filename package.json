{
  "name": "ficr-edu-1a",
  "private": true,
  "scripts": {
    "lint": "eslint \"src/**/*.js\" && prettier --check \"src/**/*.{js,css,html}\"",
    "format": "prettier --write \"src/**/*.{js,css,html}\"",
    "format:check": "prettier --check \"src/**/*.{js,css,html}\"",
    "html:validate": "html-validate \"src/**/*.html\""
  },
  "devDependencies": {
    "eslint": "^9.11.1",
    "prettier": "^3.3.3",
    "html-validate": "^9.0.0"
  }
}